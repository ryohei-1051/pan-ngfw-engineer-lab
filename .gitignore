# =========================
# Vendor images / VM disks (DO NOT COMMIT)
# =========================
*.qcow2
*.img
*.iso
*.ova
*.ovf
*.vmdk
*.vhd
*.vhdx

# =========================
# Packet captures & big artifacts (DO NOT COMMIT)
# =========================
*.pcap
*.pcapng
*.cap

# =========================
# Logs (block by default; allow small sanitized samples in evidence/)
# =========================
*.log
*.out
*.debug

# Allow sanitized evidence logs (keep them small)
!evidence/**/*.log
!modules/**/evidence/**/*.log
!evidence/**/*.txt
!modules/**/evidence/**/*.txt

# =========================
# Secrets / credentials (DO NOT COMMIT)
# =========================
.env
.env.*
*.key
*.p12
*.pfx
*id_rsa*
*id_ed25519*
*_token*
*apikey*
*api_key*
*secret*
*passwd*
*password*

# Allow public certs if you ever include them
!*.crt
!*.cer
!*.pem

# =========================
# GNS3 project/work files (optional—keep exports only if you share)
# =========================
*.gns3project
*.gns3
*.net
*.wires

# =========================
# OS / editor / python
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/
__pycache__/
*.pyc
.venv/
venv/
